# registry.ko — KLGS Game Registry (All 31 Games)
# ==================================================
# Kobra-native specification for the Ko's Labyrinth game catalog.
# Source: ambroflow/runner/registry.py
# Python shim: loaded at module import in registry.py.
#
# Mood convention: DECLARATIVE throughout.
#
# The registry is the canonical list of all 31 games.
# Each GameEntry carries: number, slug, title, subtitle, built flag.
# Two lookup dicts are derived: GAME_BY_SLUG and GAME_BY_NUMBER.
#
# Layer routing:
#   L10 NAMES  — game slug and title (Seth/Mavo)
#   L11 SCENE  — each game is a Samos cluster (scene space for its era)
#   L3  BOOLEAN — built flag (is this game playable in this build?)

# ── SECTION 0: Registry System Identity ──────────────────────────────────────
# Seth (T7 / L10 NAMES) → Samos (T7 / L11 SCENE). Same tongue. Declarative.

LoGameRegistry : Seth Samos {
  [Mavo Lo GameRegistry 7_KLGS]
  [Mavo Sao ambroflow runner registry]
  [TaShyMa Soa]
}

# ── SECTION 1: GameEntry Definition ──────────────────────────────────────────
# number: integer position in the series (1–31)
# slug:   "{number}_KLGS" — canonical game identifier
# title:  display title
# subtitle: short descriptor shown on tile selection screen (optional)
# built:  True = playable in this build; False = not yet implemented
#
# Samos (T7 / L11 SCENE) → Seth (T7 / L10 NAMES). Same tongue. Declarative.

LoGameEntry : Samos Seth {
  [Rose Wu number Oy Ye]                   # L2 DECIMAL — series position
  [Seth Wu slug title subtitle Oy Kokiel]  # L10 NAMES — identifiers
  [Mek Oy Ui built Oy Ui]                 # L3 BOOLEAN — playable flag
  [TaShyMa Gwev]
}

# ── SECTION 2: Game Catalog (All 31 Games) ───────────────────────────────────
# Full Ko's Labyrinth title list. Slug format: {number}_KLGS.
# Samos (T7 / L11 SCENE) → Mavo (T7 / L10 NAMES). Same tongue. Declarative.

