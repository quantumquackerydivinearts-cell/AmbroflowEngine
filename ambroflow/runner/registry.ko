# ── SECTION 3: Lookup Indices ─────────────────────────────────────────────────
# GAME_BY_SLUG:   dict[slug → GameEntry]
# GAME_BY_NUMBER: dict[number → GameEntry]
# Wu (T2 / L12 FUNCTION) → Samos (T7 / L11 SCENE). Declarative.

LoGameLookup : Wu Samos {
  [Ier LoGameCatalog Ha slug Wu]        # GAME_BY_SLUG: index by slug
  [Ier LoGameCatalog Ha number Wu]      # GAME_BY_NUMBER: index by number
  [Mek Oy Aonkiel game_lookup]          # L11 SCENE — lookup tables registered
  [TaShyMa Gwev]
}
